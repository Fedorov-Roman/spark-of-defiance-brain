; Spark of Defiance — Godot 4.6.3
[application]
config/name="Spark of Defiance"
config/description="2D Stealth-Platformer Metroidvania"
run/main_scene="res://scenes/test_movement.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://assets/art/placeholder/player.png"
[display]
window/size/viewport_width=640
window/size/viewport_height=360
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/stretch/scale_mode="integer"
[rendering]
textures/canvas_textures/default_texture_filter=0
2d/snap/snap_2d_transforms_to_pixel=true
2d/snap/snap_2d_vertices_to_pixel=true
[layer_names]
2d_physics/layer_1="World"
2d_physics/layer_2="Player"
2d_physics/layer_3="Enemies"
2d_physics/layer_4="NPCs"
2d_physics/layer_5="Interactables"
2d_physics/layer_6="Projectiles"
2d_physics/layer_7="Traps"
2d_physics/layer_8="GrapplePoints"
2d_physics/layer_9="HideZones"
2d_physics/layer_10="SoundEmitters"
2d_physics/layer_11="LightOccluders"
2d_physics/layer_12="Checkpoints"
[autoload]
GameState="*res://systems/autoload/game_state.gd"
SaveManager="*res://systems/autoload/save_manager.gd"
ProgressionManager="*res://systems/autoload/progression_manager.gd"
InputManager="*res://systems/autoload/input_manager.gd"
DialogueManager="*res://systems/autoload/dialogue_manager.gd"
AudioManager="*res://systems/autoload/audio_manager.gd"
TimeManager="*res://systems/autoload/time_manager.gd"
UIManager="*res://systems/autoload/ui_manager.gd"
LevelManager="*res://systems/autoload/level_manager.gd"
