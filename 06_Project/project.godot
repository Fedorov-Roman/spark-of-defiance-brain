; Engine Configuration File.
; Godot version: 4.6.3-stable

[application]
config/name="Spark of Defiance"
config/description="2D stealth platformer with metroidvania elements"
config/version="0.1.0"
run/main_scene="res://scenes/hub.tscn"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://assets/placeholder/icon.png"

[rendering]
renderer/rendering_method="mobile"
textures/canvas_textures/default_texture_filter=0

[display]
window/size/viewport_width=640
window/size/viewport_height=360
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/stretch/scale_mode="integer"

[physics]
2d/default_gravity=980.0

[layer_names]
2d_physics/layer_1="Player"
2d_physics/layer_2="Enemies"
2d_physics/layer_3="World"
2d_physics/layer_4="Traps"
2d_physics/layer_5="Collectibles"
2d_physics/layer_6="Triggers"
2d_physics/layer_7="Projectiles"
2d_physics/layer_8="Cover"
2d_physics/layer_9="UI"
2d_physics/layer_10="Particles"
2d_physics/layer_11="GrapplePoints"
2d_physics/layer_12="BossWeakPoints"

[autoload]
GameState="*res://systems/autoload/game_state.gd"
SaveManager="*res://systems/autoload/save_manager.gd"
ProgressionManager="*res://systems/autoload/progression_manager.gd"
TimeManager="*res://systems/autoload/time_manager.gd"
InputManager="*res://systems/autoload/input_manager.gd"
AudioManager="*res://systems/autoload/audio_manager.gd"
DialogueManager="*res://systems/autoload/dialogue_manager.gd"
LevelManager="*res://systems/autoload/level_manager.gd"
UIManager="*res://systems/autoload/ui_manager.gd"

